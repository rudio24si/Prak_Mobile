<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    tools:context=".Home.pertemuan_7.SatuFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <!-- Badge -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#E6F1FB"
            android:text="FRAGMENT"
            android:textColor="#185FA5"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp" />

        <!-- Nomor Besar -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="2"
            android:textColor="#1A3A5C"
            android:textSize="96sp"
            android:textStyle="bold"
            android:lineSpacingExtra="-8dp" />

        <!-- Label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dua Fragment"
            android:textColor="#1A3A5C"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="-8dp" />

        <!-- Deskripsi -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Ini adalah fragment kedua.\nFragment digunakan untuk membangun\nbagian-bagian UI secara modular."
            android:textColor="#94A3B8"
            android:textSize="13sp"
            android:gravity="center"
            android:lineSpacingExtra="4dp" />

        <!-- Divider -->
        <View
            android:layout_width="40dp"
            android:layout_height="3dp"
            android:layout_marginTop="24dp"
            android:background="#1A3A5C" />

    </LinearLayout>

</FrameLayout>